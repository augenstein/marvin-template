# MARVIN Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================================
# INTEGRATIONS
# ============================================

# Google Workspace (for Gmail, Calendar, Drive)
# Get these from Google Cloud Console or ask your admin
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Atlassian (for Jira, Confluence)
# Uses browser auth, no keys needed here

# ============================================
# API KEYS (for future integrations)
# ============================================

# Notion
NOTION_API_KEY=

# Linear
LINEAR_API_KEY=

# Slack
SLACK_BOT_TOKEN=

# OpenAI (if using for specific skills)
OPENAI_API_KEY=

# ============================================
# CLI-Based Integrations
# ============================================

# These tools handle auth via their own CLI. No keys needed here.
# Just run the auth command once:
#
# Google Workspace (gws):  gws auth login -s gmail,calendar,drive
# GitHub (gh):             gh auth login
# Agent Skills (npx):      No auth needed
#
# API key-based CLIs can be configured here:
# OPENAI_API_KEY=your-key-here
# PERPLEXITY_API_KEY=your-key-here

# ============================================
# CUSTOM
# ============================================

# Add your own keys here as needed
# MY_SERVICE_API_KEY=
